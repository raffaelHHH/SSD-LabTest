# MySQL database credentials
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress_db_password

# Port WordPress will be reachable on directly (http://localhost:<this>), bypassing the HTTPS proxy
WORDPRESS_PORT=8080
# Public site URL, served via the nginx HTTPS reverse proxy
WORDPRESS_URL=https://127.0.0.1
WORDPRESS_TITLE=My WordPress Site

# WordPress admin account (created automatically on first startup)
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=2402294@sit.singaporetech.edu.sg
WORDPRESS_ADMIN_EMAIL=arelsulistyo22@gmail.com

# Local Gitea server ports (http://localhost:<GITEA_HTTP_PORT>, ssh on <GITEA_SSH_PORT>)
GITEA_HTTP_PORT=3001
GITEA_SSH_PORT=2222

# Git commit identity configured inside the Gitea container (git user's ~/.gitconfig)
GIT_USER_NAME=Raffael-Davin-Harjanto
GIT_USER_EMAIL=2402294@sit.singaporetech.edu.sg

# Password-policy demo app (http://localhost:<PWAPP_PORT>) and its dedicated database
PWAPP_PORT=8081
PWAPP_DB_NAME=passwordapp
PWAPP_DB_USER=passwordapp
PWAPP_DB_PASSWORD=passwordapp_db_password
PWAPP_DB_ROOT_PASSWORD=change_me_pwapp_root_password
